# ─── App Mode ────────────────────────────────────
APP_MODE=paper                     # paper | live
EVENT_MODE=mock                    # live | mock | replay
DEMO_MODE=true                     # true = use demo system prompts

# ─── LLM Provider ───────────────────────────────
OPENAI_API_KEY=                    # Required — GPT-5.1 recommended
OPENAI_MODEL=gpt-5.1              # gpt-5.x uses Responses API, gpt-4.x uses Chat API
ANTHROPIC_API_KEY=                 # Optional alternative provider

# ─── Market Data ─────────────────────────────────
FMP_API_KEY=                       # Financial Modeling Prep (for real earnings scans)

# ─── Broker ──────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Avatar (Optional) ──────────────────────────
# AGORA_ENABLED=true
# AGORA_BACKEND_URL=http://localhost:8082
# AGORA_AVATAR_CLIENT_URL=http://localhost:8084
# AGORA_PROFILE=VIDEO

# ─── Database ────────────────────────────────────
DATABASE_URL=sqlite:///data/aatf.db

# ─── Server ──────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000
